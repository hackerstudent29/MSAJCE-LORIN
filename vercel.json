{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/sunday-report",
      "schedule": "20 11 * * *"
    },
    {
      "path": "/api/sunday-report",
      "schedule": "30 3 * * 0"
    }
  ]
}
